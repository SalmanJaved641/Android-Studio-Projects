<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
<item>
    <shape android:shape="rectangle">
        <solid android:color="#FFED4A"/>
        <stroke android:color="#2D44C8"
            android:width="2dp"
            android:dashWidth="7dp"
            android:dashGap="2dp" />
        <corners android:topRightRadius="21dp"
            android:bottomLeftRadius="21dp"/>
        <size android:width="200dp"
            android:height="200dp"/>
        <gradient android:startColor="#021DB1"
            android:centerColor="#11E2C3"
            android:endColor="#2DE919"
            android:angle="135"
            />

    </shape>
</item>
</selector>
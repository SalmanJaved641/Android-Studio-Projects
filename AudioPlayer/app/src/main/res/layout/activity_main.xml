<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <TextView
        android:id="@+id/textView"
        android:layout_width="468dp"
        android:layout_height="147dp"
        android:gravity="center"
        android:text="@string/audio"
        android:textColor="#00ACFB"
        android:layout_marginTop="200dp"
        android:textSize="27sp"
        android:textStyle="bold|bold|italic"
        tools:layout_editor_absoluteY="106dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="50dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#85D5FA"
            android:text="Play"
            tools:layout_editor_absoluteX="37dp"
            tools:layout_editor_absoluteY="499dp" />

        <Button
            android:id="@+id/btnPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#85D5FA"
            android:text="Pause"
            tools:layout_editor_absoluteX="162dp"
            tools:layout_editor_absoluteY="499dp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#85D5FA"
            android:text="Stop"
            tools:layout_editor_absoluteX="292dp"
            tools:layout_editor_absoluteY="499dp" />
    </LinearLayout>


    <TextView
        android:id="@+id/textView2"
        android:layout_width="309dp"
        android:layout_height="45dp"
        android:gravity="center"
        android:text="online URI is also set you can listen it by changing source data to onlineUri"
        android:textColor="#B1B1B1"
        android:textStyle="italic"
        tools:layout_editor_absoluteX="51dp"
        tools:layout_editor_absoluteY="616dp" />

</LinearLayout>